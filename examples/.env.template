# lapyme SDK Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# Security Configuration
# The SDK supports loading security credentials from environment variables
# with the prefix: LAPYME_
#
# Security environment variables:
LAPYME_API_KEY=your_api_key_here

# Optional IDs used by workflow examples:
LAPYME_CUSTOMER_ID=
LAPYME_PRODUCT_ID=
LAPYME_SUPPLIER_ID=
LAPYME_WAREHOUSE_ID=
LAPYME_POINT_OF_SALE_ID=
LAPYME_PURCHASE_ORDER_ITEM_ID=

# Debug Configuration
# Enable HTTP request/response logging for debugging
LAPYME_DEBUG=true
